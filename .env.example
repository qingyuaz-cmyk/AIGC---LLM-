# 复制此文件为 .env，填入真实值后启动 Docker

# Gemini / Azure OpenAI
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://aidp.bytedance.net/api/modelhub/online/v2/crawl
AZURE_OPENAI_MODEL=gemini-2.5-pro

# SeedAnce (ARK API Key，格式 ark-xxxx)
SEEDANCE_API_KEY=ark-your-key-here
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# TOS 对象存储
TOS_ENDPOINT=https://tos-cn-beijing.volces.com
TOS_ACCESS_KEY=your_ak_here
TOS_SECRET_KEY=your_sk_here
TOS_BUCKET=your_bucket_name
TOS_REGION=cn-beijing
